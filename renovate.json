{
  "extends": ["group:all", ":dependencyDashboard"],
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^src/pytest_servers/gcs.py$",
        "^src/pytest_servers/azure.py$"
      ],
      "matchStrings": [
        "\"(?<depName>.*?):(?<currentValue>.*)\".*?#\\s+renovate"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
